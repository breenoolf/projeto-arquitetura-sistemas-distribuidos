# =====================================================
# Sprint 2.1: Service Discovery + Master Election
# =====================================================

# --- WORKER Configuration ---
WORKER_UUID=
WORKER_ORIGIN_SERVER_UUID=
WORKER_FAIL_RATE=0.0

# --- WORKER: Timing (seconds) ---
MASTER_RESPONSE_TIMEOUT_S=5
RECONNECT_DELAY_S=3
IDLE_WAIT_S=2
PROCESSING_MIN_S=0.5
PROCESSING_MAX_S=2.0

# --- WORKER: Discovery (Sprint 2.1) ---
DISCOVERY_TIMEOUT_S=3.0
DISCOVERY_PORT=5000
DISCOVERY_BROADCAST_ADDR=255.255.255.255

# --- MASTER Configuration ---
MASTER_SERVER_UUID=Master_A
MASTER_NAME=MASTER_A
MASTER_IP=127.0.0.1
MASTER_TCP_PORT=8888

# --- MASTER: Discovery Listen (Sprint 2.1) ---
DISCOVERY_LISTEN_ADDR=0.0.0.0
DISCOVERY_PORT=5000

# --- MASTER: Tasks & Logging ---
MASTER_TASK_USERS=Michel,Julia
MASTER_LOG_PATH=master_log.txt

# =====================================================
# Sprint 3: Protocolo de Negociação Master-to-Master
# =====================================================

# --- MASTER: P2P Negotiation (Sprint 3) ---
# Formato: "master_name:ip:port,master_name:ip:port"
MASTER_NEIGHBORS=MASTER_B:127.0.0.1:8889
MASTER_P2P_PORT=9999
MASTER_SATURATION_THRESHOLD=100
MASTER_RELEASE_THRESHOLD=60

# --- MASTER: Load Monitoring (Sprint 3) ---
# Configurações para monitoramento de requisições pendentes
LOAD_CHECK_INTERVAL_S=2

